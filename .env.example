# ── Database ───────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://user:password@localhost:5432/kaligpt
PGHOST=localhost
PGPORT=5432
PGUSER=kaligpt
PGPASSWORD=your_secure_password
PGDATABASE=kaligpt

# ── Authentication ─────────────────────────────────────────────────────────────
JWT_SECRET=generate_with_openssl_rand_hex_64
SESSION_SECRET=generate_with_openssl_rand_hex_32
ADMIN_SECRET=generate_with_openssl_rand_hex_32

# ── AI Providers ───────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...
GROQ_API_KEY=gsk_...
GOOGLE_GEMINI_API_KEY=AIza...
OPENROUTER_API_KEY=sk-or-...

# ── Stripe Payment ────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRO_PRICE_ID=price_...
STRIPE_ENTERPRISE_PRICE_ID=price_...

# ── Replit OAuth ──────────────────────────────────────────────────────────────
REPLIT_CLIENT_ID=...
REPLIT_CLIENT_SECRET=...
REPL_ID=...
REPLIT_DOMAINS=your-repl.replit.app

# ── App Config ────────────────────────────────────────────────────────────────
APP_URL=https://mr7.ai
NODE_ENV=production
PORT=8080
ALLOWED_ORIGINS=https://mr7.ai,https://www.mr7.ai

# ── Internal Security ─────────────────────────────────────────────────────────
INTERNAL_API_KEY=generate_with_openssl_rand_hex_32

# ── Email (Resend or SendGrid) ────────────────────────────────────────────────
RESEND_API_KEY=re_...
EMAIL_FROM=noreply@mr7.ai

# ── Monitoring & Logging ──────────────────────────────────────────────────────
SENTRY_DSN=https://...@sentry.io/...
LOG_LEVEL=info

# ── Crypto Payments (Optional) ────────────────────────────────────────────────
NOWPAYMENTS_API_KEY=...
COINBASE_COMMERCE_API_KEY=...

# ── OSINT APIs (Optional) ────────────────────────────────────────────────────
SHODAN_API_KEY=...
CENSYS_API_ID=...
CENSYS_API_SECRET=...
