# ============================================================
# mr7.ai — Environment Variables Reference
# Copy to .env and fill in your values.
# NEVER commit .env to git.
# ============================================================

# ── DATABASE ─────────────────────────────────────────────────
# PostgreSQL connection string.
# Local dev: postgresql://mr7:mr7_dev_password@localhost:5432/mr7ai
# Replit:    Auto-provisioned — copy from Replit DB panel.
DATABASE_URL=postgresql://mr7:mr7_dev_password@localhost:5432/mr7ai
PGHOST=localhost
PGPORT=5432
PGUSER=mr7
PGPASSWORD=mr7_dev_password
PGDATABASE=mr7ai

# ── REDIS ─────────────────────────────────────────────────────
# Used for: rate limiting, session caching, job queues, pub/sub.
REDIS_URL=redis://:mr7_redis_dev_password@localhost:6379

# ── SERVER ────────────────────────────────────────────────────
PORT=8080
NODE_ENV=development
ALLOWED_ORIGINS=http://localhost:5000,http://localhost:3000

# ── SECURITY ──────────────────────────────────────────────────
# Generate: openssl rand -base64 64
SESSION_SECRET=change-me-to-a-random-64-char-string-in-production
JWT_SECRET=change-me-to-another-random-64-char-string-in-production
JWT_EXPIRES_IN=24h
# Generate: openssl rand -hex 32
INTERNAL_API_KEY=change-me-to-a-hex-string

# ── AI PROVIDERS ──────────────────────────────────────────────
# OpenAI — GPT-4o, GPT-4o-mini, embeddings
# Get key: https://platform.openai.com/api-keys
# On Replit: use the built-in OpenAI integration instead.
OPENAI_API_KEY=sk-...

# Anthropic — Claude Opus/Sonnet/Haiku
# Get key: https://console.anthropic.com/
# On Replit: use the built-in Anthropic integration instead.
ANTHROPIC_API_KEY=sk-ant-...

# Google Gemini (optional) — https://makersuite.google.com/app/apikey
GOOGLE_AI_API_KEY=

# Groq — ultra-fast inference (optional) — https://console.groq.com/
GROQ_API_KEY=

# Mistral AI (optional)
MISTRAL_API_KEY=

# Ollama — local LLMs (optional)
OLLAMA_BASE_URL=http://localhost:11434

DEFAULT_MODEL=gpt-4o

# ── REPLIT INTEGRATION ────────────────────────────────────────
# Auto-set by Replit. Do NOT set manually unless outside Replit.
REPLIT_AI_BASE_URL=

# ── AUTHENTICATION ────────────────────────────────────────────
# Replit OAuth (auto-configured via Replit Auth integration)
REPLIT_CLIENT_ID=
REPLIT_CLIENT_SECRET=

# Google OAuth — https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# GitHub OAuth — https://github.com/settings/developers
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# ── EMAIL / SMTP ──────────────────────────────────────────────
# Local dev: MailHog (port 1025 SMTP, http://localhost:8025 UI)
# Production: SendGrid, Mailgun, AWS SES, Postmark
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
EMAIL_FROM=noreply@mr7.ai
EMAIL_FROM_NAME=mr7.ai

# ── PAYMENTS (STRIPE) ─────────────────────────────────────────
# Get keys: https://dashboard.stripe.com/apikeys
# Use sk_test_... in development
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_STARTER_MONTHLY=price_...
STRIPE_PRICE_STARTER_YEARLY=price_...
STRIPE_PRICE_PROFESSIONAL_MONTHLY=price_...
STRIPE_PRICE_PROFESSIONAL_YEARLY=price_...
STRIPE_PRICE_ELITE_MONTHLY=price_...
STRIPE_PRICE_ELITE_YEARLY=price_...

# ── FILE STORAGE ──────────────────────────────────────────────
# Local dev: ./uploads directory (auto-created)
# Production: S3, Cloudflare R2, or Supabase Storage
STORAGE_PROVIDER=local
S3_BUCKET_NAME=
S3_REGION=us-east-1
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_ENDPOINT=
MAX_UPLOAD_SIZE=52428800

# ── VECTOR DATABASE ───────────────────────────────────────────
VECTOR_PROVIDER=pgvector
PINECONE_API_KEY=
PINECONE_ENVIRONMENT=
PINECONE_INDEX=

# ── RATE LIMITING ─────────────────────────────────────────────
RATE_LIMIT_GLOBAL=2000
RATE_LIMIT_AI=100
RATE_LIMIT_AUTH=20

# ── MONITORING ────────────────────────────────────────────────
# Sentry DSN: https://sentry.io/
SENTRY_DSN=
LOG_LEVEL=info
OTEL_EXPORTER_OTLP_ENDPOINT=
OTEL_SERVICE_NAME=mr7ai-api

# ── WEBHOOKS ──────────────────────────────────────────────────
# Generate: openssl rand -hex 32
WEBHOOK_SIGNING_SECRET=change-me-webhook-signing-secret

# ── PENTEST LAB ───────────────────────────────────────────────
PENTEST_LAB_PORT=8000
FAISS_INDEX_PATH=./pentest-lab/data/faiss

# ── BACKUP ────────────────────────────────────────────────────
BACKUP_DIR=/backups/postgres
BACKUP_KEEP_DAYS=30

# ── FEATURE FLAGS ─────────────────────────────────────────────
FEATURE_COUNCIL_MODE=true
FEATURE_FUSION_MODE=true
FEATURE_MARKETPLACE=true
FEATURE_TEAMS=true
FEATURE_KNOWLEDGE_BASE=true
FEATURE_WEBHOOKS=true
FEATURE_API_KEYS=true
FEATURE_PENTEST_LAB=true

# ── DEV ONLY (must be false/unset in production) ──────────────
DEBUG_SQL=false
SEED_DATABASE=false
MOCK_AI_RESPONSES=false
